PORT=3001
NODE_ENV=development

# REQUIRED (every env). Must be at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

LOG_LEVEL=info
# Wildcard is permitted in development only; production rejects "*" at boot.
CORS_ORIGIN=*
EXTENSION_ORIGINS=chrome-extension://<your-published-extension-id>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
