{
  "name": "clairity",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "extension"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold\" --names \"BACKEND,EXTENSION\" \"npm run dev --workspace=backend\" \"npm run dev --workspace=extension\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=backend && npm run build --workspace=extension",
    "test": "npm test --workspace=backend",
    "typecheck": "npm run typecheck --workspace=backend"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1"
  }
}