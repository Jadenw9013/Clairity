PORT=3001
NODE_ENV=development
LLM_PROVIDER=openai
LLM_API_KEY=
SESSION_SECRET=change-me-to-a-random-32-char-string
RATE_LIMIT_RPM=60
LOG_LEVEL=info
CORS_ORIGIN=*

# ─── MCS daemon (optional, local-only context enrichment) ────────────────────
# The MCS daemon (ctx-daemon) runs on port 4040 by default.
# NOTE: port 4041 is ctx-cloud (Express/Supabase API) — do NOT use for pack/context.

# Kill switch: set to "true" to enable MCS context lookups
MCS_ENABLED=false

# Daemon base URL
MCS_BASE_URL=http://localhost:4040

# Context mode: off | auto | pinned
#   off    = MCS enabled but no context lookups (useful for health-check only)
#   auto   = fetch context if daemon is available
#   pinned = fetch only specific categories (see MCS_PINNED_CATEGORIES)
MCS_CONTEXT_MODE=auto

# Timeout for MCS HTTP requests (ms). Fast-fail for local dev.
MCS_TIMEOUT_MS=2000

# Max number of context items to pull from MCS pack
MCS_MAX_ITEMS=10

# Max total characters of assembled context to inject into the rewrite prompt
MCS_MAX_CONTEXT_TOKENS=4000

# Comma-separated pinned categories (only used when MCS_CONTEXT_MODE=pinned)
MCS_PINNED_CATEGORIES=
