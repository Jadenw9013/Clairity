# Clairity Backend Environment Variables
# Copy to .env and fill in values. NEVER commit .env itself.

# Required in production (≥16 chars, used for HMAC token signing)
SESSION_SECRET=

# Server port (default: 3001)
PORT=3001

# Pino log level (default: info)
LOG_LEVEL=info

# NODE_ENV: development | production
NODE_ENV=development

# CORS: comma-separated web origins (required in production, cannot be * in production)
CORS_ORIGIN=http://localhost:3001

# Chrome extension origins (comma-separated, required in production)
# In development, ALL chrome-extension:// origins are auto-allowed.
# In production, only origins listed here are allowed.
EXTENSION_ORIGINS=chrome-extension://<your-published-extension-id>
